{
  "name": "fantasy-bot",
  "version": "0.1.0",
  "private": true,
  "description": "Standalone Telegram fantasy bot extracted from edgetrader-bot",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "smoke": "tsx tmp/e2e-flow-smoke.ts",
    "pajcash:session": "tsx src/pajcash-session.ts",
    "fly:secrets:dry-run": "scripts\\fly-stage-secrets.cmd -DryRun",
    "fly:secrets:stage": "scripts\\fly-stage-secrets.cmd",
    "wallet:sweep:selected": "tsx scripts/sweep-selected-wallets-to-treasury.ts",
    "wallet:reconcile": "tsx tmp/reconcile-fantasy-wallets.ts",
    "wallet:reset-all": "tsx tmp/reconcile-fantasy-wallets.ts -- --reset-all"
  },
  "packageManager": "pnpm@10.30.3",
  "dependencies": {
    "@ai-sdk/groq": "^3.0.39",
    "@ai-sdk/xai": "^3.0.91",
    "@napi-rs/canvas": "^0.1.100",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "@supabase/supabase-js": "^2.98.0",
    "ai": "^6.0.185",
    "chart.js": "^4.5.1",
    "chartjs-node-canvas": "^5.0.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "grammy": "^1.41.0",
    "ioredis": "^5.10.0",
    "tsx": "^4.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.3",
    "typescript": "^5.9.3"
  }
}
